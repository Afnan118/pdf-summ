{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "client/dist" }
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "server/server.js" },
    { "source": "/((?!assets/|public/|favicon.ico|vite.svg).*)", "destination": "/index.html" }
  ]
}
